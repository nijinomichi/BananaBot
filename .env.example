# 🍌 BananaBot — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub.

# ── Discord ──────────────────────────────────────────
# Required. Get from Discord Developer Portal.
DISCORD_BOT_TOKEN=

# Can be made public, but kept here for consistency.
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=

# ── OpenAI ───────────────────────────────────────────
# Required for AI features.
OPENAI_API_KEY=

# ── Pinata / IPFS ────────────────────────────────────
# Required for NFT metadata and image storage.
PINATA_JWT=

# ── Notes ────────────────────────────────────────────
# Store all of the above in:
#   Replit  → Secrets tab
#   GitHub  → Settings > Secrets and variables > Actions
# Never paste real values into source code or Notion body.
