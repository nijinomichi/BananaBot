# BananaBot — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to GitHub.

# ─── Discord ───────────────────────────────────────────
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_APPLICATION_ID=your_application_id_here
DISCORD_PUBLIC_KEY=your_public_key_here

# ─── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Pinata (IPFS) ─────────────────────────────────────
PINATA_JWT=your_pinata_jwt_here

# ─── Notes ─────────────────────────────────────────────
# DISCORD_APPLICATION_ID and DISCORD_PUBLIC_KEY are not strictly secret
# but are kept here for consistency and to prevent operational mistakes.
# All real values go into Replit Secrets or GitHub Secrets — never here.
